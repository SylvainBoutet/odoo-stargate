<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stargate_glyph_list" model="ir.ui.view">
        <field name="name">stargate.glyph.list</field>
        <field name="model">stargate.glyph</field>
        <field name="arch" type="xml">
            <list string="Glyphs" default_order="number">
                <field name="image" widget="image" options="{'size': [32, 32]}"/>
                <field name="number"/>
                <field name="name"/>
                <field name="gate_type"/>
                <field name="is_point_of_origin" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_stargate_glyph_form" model="ir.ui.view">
        <field name="name">stargate.glyph.form</field>
        <field name="model">stargate.glyph</field>
        <field name="arch" type="xml">
            <form string="Glyph">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Constellation"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="number"/>
                            <field name="gate_type"/>
                            <field name="is_point_of_origin"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="SVG Shape" name="svg">
                            <field name="svg" placeholder="Optional inline SVG markup for the dialing interface."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_stargate_glyph_kanban" model="ir.ui.view">
        <field name="name">stargate.glyph.kanban</field>
        <field name="model">stargate.glyph</field>
        <field name="arch" type="xml">
            <kanban default_order="number">
                <field name="is_point_of_origin"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex flex-column align-items-center text-center p-2">
                            <field name="image" widget="image" options="{'size': [64, 64]}"/>
                            <strong class="mt-1">
                                <field name="number"/> · <field name="name"/>
                            </strong>
                            <span t-if="record.is_point_of_origin.raw_value" class="badge text-bg-warning mt-1">
                                Point of Origin
                            </span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_stargate_glyph_search" model="ir.ui.view">
        <field name="name">stargate.glyph.search</field>
        <field name="model">stargate.glyph</field>
        <field name="arch" type="xml">
            <search string="Glyphs">
                <field name="name"/>
                <field name="number"/>
                <filter name="point_of_origin" string="Point of Origin" domain="[('is_point_of_origin', '=', True)]"/>
                <group name="group_by">
                    <filter name="group_gate_type" string="Gate Type" context="{'group_by': 'gate_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_stargate_glyph" model="ir.actions.act_window">
        <field name="name">Glyphs</field>
        <field name="res_model">stargate.glyph</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_stargate_glyph_search"/>
    </record>
</odoo>
