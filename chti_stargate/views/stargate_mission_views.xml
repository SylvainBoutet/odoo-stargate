<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stargate_mission_list" model="ir.ui.view">
        <field name="name">stargate.mission.list</field>
        <field name="model">stargate.mission</field>
        <field name="arch" type="xml">
            <list string="Missions" decoration-success="state == 'success'"
                  decoration-danger="state in ('failed', 'mia')"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="planet_id"/>
                <field name="team_id"/>
                <field name="leader_id"/>
                <field name="threat_level"/>
                <field name="date_start"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'success'"
                       decoration-danger="state in ('failed', 'mia')"
                       decoration-info="state == 'in_progress'"/>
            </list>
        </field>
    </record>

    <record id="view_stargate_mission_kanban" model="ir.ui.view">
        <field name="name">stargate.mission.kanban</field>
        <field name="model">stargate.mission</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" highlight_color="color">
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <small class="o_kanban_record_subtitle text-muted">
                                    <field name="planet_id"/>
                                </small>
                            </div>
                        </div>
                        <div class="o_kanban_record_body">
                            <field name="team_id"/>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <span class="badge text-bg-warning">
                                <field name="threat_level"/>
                            </span>
                            <field name="leader_id" widget="many2one_avatar_user"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_stargate_mission_form" model="ir.ui.view">
        <field name="name">stargate.mission.form</field>
        <field name="model">stargate.mission</field>
        <field name="arch" type="xml">
            <form string="Mission Report">
                <header>
                    <button name="action_schedule" type="object" string="Schedule"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_start" type="object" string="Depart"
                            class="btn-primary" invisible="state not in ('draft', 'scheduled')"/>
                    <button name="action_success" type="object" string="Mission Success"
                            class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_failed" type="object" string="Mission Failed"
                            invisible="state != 'in_progress'"/>
                    <button name="action_mia" type="object" string="Declare MIA"
                            invisible="state != 'in_progress'"/>
                    <button name="action_reset" type="object" string="Reset to Draft"
                            invisible="state in ('draft',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,scheduled,in_progress,success"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Mission title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="planet_id"/>
                            <field name="designation"/>
                            <field name="address_display"/>
                            <field name="team_id"/>
                            <field name="leader_id"/>
                        </group>
                        <group>
                            <field name="threat_level"/>
                            <field name="malp_recon"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Objective" name="objective">
                            <field name="objective" placeholder="Mission objective..."/>
                        </page>
                        <page string="Report" name="report">
                            <field name="report" placeholder="After-action report..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_stargate_mission_search" model="ir.ui.view">
        <field name="name">stargate.mission.search</field>
        <field name="model">stargate.mission</field>
        <field name="arch" type="xml">
            <search string="Missions">
                <field name="name"/>
                <field name="planet_id"/>
                <field name="team_id"/>
                <field name="leader_id"/>
                <separator/>
                <filter name="ongoing" string="Ongoing" domain="[('state', '=', 'in_progress')]"/>
                <filter name="scheduled" string="Scheduled" domain="[('state', '=', 'scheduled')]"/>
                <filter name="success" string="Success" domain="[('state', '=', 'success')]"/>
                <filter name="failed" string="Failed / MIA" domain="[('state', 'in', ('failed', 'mia'))]"/>
                <group name="group_by">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_team" string="Team" context="{'group_by': 'team_id'}"/>
                    <filter name="group_planet" string="Destination" context="{'group_by': 'planet_id'}"/>
                    <filter name="group_threat" string="Threat Level" context="{'group_by': 'threat_level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_stargate_mission" model="ir.actions.act_window">
        <field name="name">Missions</field>
        <field name="res_model">stargate.mission</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_stargate_mission_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Log an off-world mission</p>
            <p>Assign a team to a destination, set the objective and record the after-action report.</p>
        </field>
    </record>
</odoo>
