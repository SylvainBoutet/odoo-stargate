<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="chti_stargate.DialingComputer">
        <div class="o_stargate" t-ref="root" t-att-class="{ 'o_stargate_engaged': state.status === 'ENGAGED' }">

            <!-- Barre de contrôle -->
            <div class="o_sg_topbar">
                <div class="o_sg_topbar_left">
                    <button t-if="!isPublic" class="o_sg_btn o_sg_btn_back" t-on-click="exit"
                            t-att-disabled="state.dialing" title="Back to Odoo">
                        ⟵ Odoo
                    </button>
                    <span class="o_sg_brand">STARGATE · DIALING COMPUTER</span>
                    <button class="o_sg_btn o_sg_btn_chti" t-on-click="toggleAbout"
                            title="À propos · CHTI-TECH">
                        CHTI-TECH
                    </button>
                </div>
                <div class="o_sg_controls">
                    <select class="o_sg_select" t-on-change="loadPlanet">
                        <option value="">— Quick dial a destination —</option>
                        <t t-foreach="state.planets" t-as="planet" t-key="planet.id">
                            <option t-att-value="planet.id"
                                    t-att-selected="planet.id === state.selectedPlanetId">
                                <t t-esc="planet.name"/>
                                <t t-if="planet.designation"> (<t t-esc="planet.designation"/>)</t>
                            </option>
                        </t>
                    </select>
                    <button class="o_sg_btn o_sg_btn_dial" t-on-click="dial"
                            t-att-disabled="state.dialing or !state.sequence.length">
                        DIAL
                    </button>
                    <button class="o_sg_btn" t-on-click="removeLast"
                            t-att-disabled="state.dialing or !state.sequence.length">⌫</button>
                    <button class="o_sg_btn" t-on-click="reset"
                            t-att-disabled="state.dialing">RESET</button>
                    <button class="o_sg_btn o_sg_btn_mute" t-on-click="toggleMute"
                            t-att-title="state.muted ? 'Unmute' : 'Mute'">
                        <t t-esc="state.muted ? '🔇' : '🔊'"/>
                    </button>
                </div>
            </div>

            <div class="o_sg_body">

                <!-- Palette des 39 glyphes -->
                <div class="o_sg_palette">
                    <div class="o_sg_panel_title">GLYPHS · FILE ARCHIVE</div>
                    <div class="o_sg_glyph_grid">
                        <t t-foreach="state.glyphs" t-as="glyph" t-key="glyph.id">
                            <button class="o_sg_glyph"
                                    t-att-class="{ 'o_sg_glyph_used': state.sequence.some(g => g.id === glyph.id),
                                                   'o_sg_glyph_poo': glyph.is_point_of_origin }"
                                    t-att-title="glyph.number + ' · ' + glyph.name"
                                    t-on-click="() => this.addGlyph(glyph)">
                                <div class="o_sg_glyph_shape" t-out="glyph.shape"/>
                                <span class="o_sg_glyph_num" t-esc="glyph.number"/>
                            </button>
                        </t>
                    </div>
                </div>

                <!-- Anneau central -->
                <div class="o_sg_gate">
                  <div class="o_sg_gate_ring">
                    <svg class="o_sg_gate_svg" t-att-viewBox="'0 0 ' + gateSize + ' ' + gateSize"
                         preserveAspectRatio="xMidYMid meet">
                        <defs>
                            <!-- Profondeur du vortex : centre lumineux → bleu profond -->
                            <radialGradient id="sg_horizon_grad" cx="50%" cy="42%" r="62%">
                                <stop offset="0%" stop-color="#eafdff"/>
                                <stop offset="28%" stop-color="#6fd6f2"/>
                                <stop offset="62%" stop-color="#1c7fd6"/>
                                <stop offset="100%" stop-color="#072a5e"/>
                            </radialGradient>
                            <!-- Surface d'eau qui ondule (turbulence animée + déplacement) -->
                            <filter id="sg_water" x="-25%" y="-25%" width="150%" height="150%">
                                <feTurbulence type="turbulence" baseFrequency="0.011 0.018"
                                              numOctaves="2" seed="7" result="noise">
                                    <animate attributeName="baseFrequency" dur="16s"
                                             values="0.011 0.018;0.02 0.012;0.011 0.018"
                                             repeatCount="indefinite"/>
                                </feTurbulence>
                                <feDisplacementMap in="SourceGraphic" in2="noise" scale="22"
                                                   xChannelSelector="R" yChannelSelector="G"/>
                            </filter>
                        </defs>
                        <!-- Anneaux -->
                        <circle class="o_sg_ring_outer" t-att-cx="center" t-att-cy="center" r="248"/>
                        <circle class="o_sg_ring_track" t-att-cx="center" t-att-cy="center" r="206"/>
                        <circle class="o_sg_ring_inner" t-att-cx="center" t-att-cy="center" r="150"/>

                        <!-- Anneau des symboles : graduations + 39 glyphes gravés, tourne sur lui-même -->
                        <g class="o_sg_inner_ring"
                           t-att-style="'transform: rotate(' + state.ringAngle + 'deg); transition: transform ' + state.ringDuration + 's linear'">
                            <t t-foreach="ticks" t-as="tick" t-key="tick.index">
                                <line class="o_sg_tick" x1="270" y1="58" x2="270" y2="74"
                                      t-att-transform="'rotate(' + tick.rotation + ' ' + center + ' ' + center + ')'"/>
                            </t>
                            <t t-foreach="ringGlyphs" t-as="rg" t-key="rg.id">
                                <g t-att-transform="'translate(' + rg.x + ' ' + rg.y + ') rotate(' + rg.rotation + ')'">
                                    <foreignObject x="-15" y="-15" width="30" height="30">
                                        <div xmlns="http://www.w3.org/1999/xhtml" class="o_sg_ring_glyph"
                                             t-out="rg.shape"/>
                                    </foreignObject>
                                </g>
                            </t>
                        </g>

                        <!-- Vortex (event horizon) — flaque d'eau ondulante + ondes concentriques -->
                        <g class="o_sg_horizon_group"
                           t-att-style="state.status === 'ENGAGED' ? 'opacity:1' : 'opacity:0'">
                            <circle class="o_sg_horizon" t-att-cx="center" t-att-cy="center" r="148"
                                    fill="url(#sg_horizon_grad)" filter="url(#sg_water)"/>
                            <circle class="o_sg_horizon_sheen" t-att-cx="center" t-att-cy="center" r="148"/>
                            <circle class="o_sg_ripple" t-att-cx="center" t-att-cy="center" fill="none">
                                <animate attributeName="r" values="30;146" dur="4.5s" repeatCount="indefinite"/>
                                <animate attributeName="opacity" values="0.55;0" dur="4.5s" repeatCount="indefinite"/>
                            </circle>
                            <circle class="o_sg_ripple" t-att-cx="center" t-att-cy="center" fill="none">
                                <animate attributeName="r" values="30;146" dur="4.5s" begin="2.25s" repeatCount="indefinite"/>
                                <animate attributeName="opacity" values="0.55;0" dur="4.5s" begin="2.25s" repeatCount="indefinite"/>
                            </circle>
                        </g>
                        <!-- Kawoosh : éruption instable au moment de l'établissement du wormhole -->
                        <circle class="o_sg_kawoosh"
                                t-att-class="{ 'o_sg_kawoosh_play': state.kawoosh }"
                                t-att-cx="center" t-att-cy="center" r="148"
                                fill="url(#sg_horizon_grad)"/>

                        <!-- Chevrons (fixes). Celui du haut plonge pour verrouiller chaque symbole. -->
                        <g class="o_sg_chevrons">
                            <t t-foreach="chevrons" t-as="chevron" t-key="chevron.index">
                                <g t-att-transform="'translate(' + chevron.x + ' ' + chevron.y + ') rotate(' + chevron.rotation + ')'">
                                    <polygon class="o_sg_chevron"
                                             t-att-class="{ 'o_sg_chevron_locked': chevron.locked,
                                                            'o_sg_chevron_top': chevron.isTop,
                                                            'o_sg_chevron_dip': chevron.isTop and state.topLocking }"
                                             points="-18,12 0,-14 18,12 11,12 0,-1 -11,12"/>
                                </g>
                            </t>
                        </g>
                    </svg>

                    <!-- Symbole verrouillé en grand au centre, glisse ensuite dans sa case -->
                    <div class="o_sg_center_stage" t-if="state.centerGlyph">
                        <div class="o_sg_center_shape" t-ref="center" t-out="state.centerGlyph.shape"/>
                    </div>
                  </div>

                    <!-- Statut -->
                    <div class="o_sg_status">
                        <div class="o_sg_status_label" t-esc="state.status"/>
                        <div class="o_sg_status_addr" t-esc="addressText"/>
                    </div>
                </div>

                <!-- Slots de l'adresse -->
                <div class="o_sg_slots">
                    <div class="o_sg_panel_title">ADDRESS</div>
                    <t t-foreach="slots" t-as="slot" t-key="slot.position">
                        <div class="o_sg_slot" t-att-data-pos="slot.position"
                             t-att-class="{ 'o_sg_slot_filled': slot.glyph,
                                            'o_sg_slot_poo': slot.position === 7 }">
                            <span class="o_sg_slot_index" t-esc="slot.position"/>
                            <t t-if="slot.glyph">
                                <div class="o_sg_slot_shape" t-out="slot.glyph.shape"/>
                            </t>
                            <t t-else="">
                                <span class="o_sg_slot_empty">—</span>
                            </t>
                        </div>
                    </t>
                </div>

            </div>

            <!-- Vitrine CHTI-TECH (backend + frontend) -->
            <div t-if="state.showAbout" class="o_sg_about" t-on-click="toggleAbout">
                <div class="o_sg_about_card" t-on-click.stop="() => {}">
                    <button class="o_sg_about_close" t-on-click="toggleAbout" title="Close">✕</button>
                    <div class="o_sg_about_brand">CHTI-TECH</div>
                    <p class="o_sg_about_text">
                        Conseil et développement <strong>Odoo</strong> : modules métier,
                        intégrations, IoT et applications sur mesure.
                        Valenciennes, Hauts-de-France.
                    </p>
                    <p class="o_sg_about_text o_sg_about_muted">
                        Ce simulateur de numérotation Stargate est une démo technique
                        (Odoo 19 · OWL · Web Audio).
                    </p>
                    <a class="o_sg_about_link" href="https://chti-tech.eu"
                       target="_blank" rel="noopener noreferrer">
                        Visiter chti-tech.eu →
                    </a>
                </div>
            </div>

        </div>
    </t>

</templates>
